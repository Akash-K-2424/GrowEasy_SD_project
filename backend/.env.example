# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Which LLM powers the CRM field extraction: anthropic | openai | gemini | mock
# "mock" uses a deterministic keyword-based mapper with no API key/cost -- handy
# for trying out the upload -> preview -> import -> results flow locally, but it
# is not a substitute for the real providers' ambiguous-column reasoning.
LLM_PROVIDER=anthropic

# Only the key for the selected LLM_PROVIDER is required.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# How many CSV rows are sent to the AI per request, and how many times a
# failed batch is retried (with exponential backoff) before being skipped.
BATCH_SIZE=25
BATCH_RETRY_ATTEMPTS=3

# Max upload size in megabytes.
MAX_UPLOAD_MB=10
